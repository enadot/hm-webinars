// PostgreSQL (Neon) for both local dev and production.
//   DATABASE_URL  = pooled connection (used at runtime / serverless)
//   DIRECT_URL    = direct connection (used for migrations)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Campaign {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  templateId        String
  config            String   // JSON-encoded CampaignConfig
  leadsWebhookUrl   String?
  published         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  leads             Lead[]
  emails            EmailTemplate[]
}

// Per-campaign email template that can be sent / scheduled via שלח מסר.
model EmailTemplate {
  id               String    @id @default(cuid())
  campaignId       String
  campaign         Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name             String    // internal label, e.g. "תזכורת 24 שעות"
  subject          String
  html             String
  senderEmail      String?
  senderName       String?
  scheduledAt      String?   // literal Asia/Jerusalem datetime "YYYY-MM-DDTHH:mm"
  sentAt           DateTime?
  sendmsgMessageId Int?      // returned by sendmsg on successful dispatch
  status           String    @default("draft") // draft | scheduled | sent | failed
  errorMessage     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([campaignId])
}

// Global key/value app settings (e.g. third-party API credentials).
// Stored as plaintext — DB access is admin-only; only read server-side.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Lead {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  email       String
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([campaignId])
}
