# Copy this file to .env.local and fill in real values.

# Database (dev: SQLite, prod on Vercel: change provider in prisma/schema.prisma to postgresql)
DATABASE_URL="file:./dev.db"

# Admin password (shared by everyone with /admin access).
# Generate a strong one: e.g. `openssl rand -hex 24`
ADMIN_PASSWORD="change-me-to-something-strong"

# Secret used to sign admin session cookies. Generate: `openssl rand -hex 32`
SESSION_SECRET="change-me-32-bytes-of-random"

# Default webhook URL (used when a campaign hasn't set its own).
# The payload is JSON: { name, phone, email, source, submittedAt, campaignSlug }
LEADS_WEBHOOK_URL=

# Vercel Blob token (production image uploads). Get one via: `vercel blob create` or dashboard.
# When unset, uploads fall back to /public/uploads/ (works locally; not persistent on Vercel).
BLOB_READ_WRITE_TOKEN=
